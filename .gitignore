# Environment variables — generated copies only
# (root .env is tracked as a template with placeholder keys)

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
venv/
backend/venv/

# Node.js
node_modules/
.next/
*.tsbuildinfo
next-env.d.ts


# IDE / Agents
.vscode/
.idea/
.cursor/
.agents/
.gemini/

# Build artifacts
/build/
/out/

# Synced env files (generated by start.sh)
backend/.env
frontend/.env.local

# TTS models (large binary files)
backend/models/

# Debug logs
npm-debug.log*
yarn-debug.log*
